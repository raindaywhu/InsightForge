# InsightForge 环境变量配置

# ============================================
# 阿里云 DashScope API 配置 (GLM-5 via Coding API)
# ============================================
# 主 API Key (用于 LLM 和 Embedding)
DASHSCOPE_API_KEY=your-dashscope-api-key-here

# OpenAI 兼容配置 (CrewAI 自动使用)
OPENAI_API_KEY=your-dashscope-api-key-here
OPENAI_API_BASE=https://coding.dashscope.aliyuncs.com/v1

# ============================================
# 模型配置
# ============================================
# 主模型 - GLM-5 (via Coding API)
DASHSCOPE_MODEL_NAME=glm-5

# Embedding 模型 (用于 RAG)
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3

# CrewAI LLM 配置 (必需)
OPENAI_MODEL_NAME=glm-5

# ============================================
# 存储配置 (可选)
# ============================================
# ChromaDB 持久化目录
CHROMA_PERSIST_DIRECTORY=./chroma_db

# Mem0 记忆存储目录
MEM0_STORAGE_DIR=./mem0_storage

# ============================================
# 输出配置 (可选)
# ============================================
# 输出目录
OUTPUT_DIR=./output