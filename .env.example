# InsightForge 环境变量配置

# ============================================
# 阿里云 DashScope API 配置 (必需)
# ============================================
# 主 API Key (用于 LLM 和 Embedding)
DASHSCOPE_API_KEY=your-dashscope-api-key-here

# ============================================
# 模型配置 (可选，使用默认值即可)
# ============================================
# 主模型 - GLM-4 或 Qwen 系列
DASHSCOPE_MODEL_NAME=qwen-plus

# Embedding 模型 (用于 RAG)
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3

# ============================================
# 存储配置 (可选)
# ============================================
# ChromaDB 持久化目录
CHROMA_PERSIST_DIRECTORY=./chroma_db

# Mem0 记忆存储目录
MEM0_STORAGE_DIR=./mem0_storage

# ============================================
# 输出配置 (可选)
# ============================================
# 输出目录
OUTPUT_DIR=./output