# InsightForge 环境变量配置

# ============================================
# OpenAI API 配置 (必需)
# ============================================
OPENAI_API_KEY=sk-your-api-key-here

# ============================================
# 模型配置 (可选)
# ============================================
# 主模型
OPENAI_MODEL_NAME=gpt-4-turbo

# Embedding 模型 (用于 RAG)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ============================================
# 存储配置 (可选)
# ============================================
# ChromaDB 持久化目录
CHROMA_PERSIST_DIRECTORY=./chroma_db

# Mem0 记忆存储目录
MEM0_STORAGE_DIR=./mem0_storage

# ============================================
# 输出配置 (可选)
# ============================================
# 输出目录
OUTPUT_DIR=./output