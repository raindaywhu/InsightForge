# InsightForge 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# ============================================
# 🚨 安全警告：切勿将 .env 文件提交到 Git！
# ============================================

# LLM 配置 (GLM-5 via Coding API)
OPENAI_API_KEY=your-api-key-here
OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL_NAME=glm-5

# Embedding API 配置 (DashScope)
DASHSCOPE_API_KEY=your-dashscope-key-here
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3

# 可选：使用单独的 Embedding 配置
# EMBEDDING_API_KEY=your-embedding-key-here
# EMBEDDING_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1